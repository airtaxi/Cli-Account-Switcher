<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="CodexAccountSwitch.WinUI.Dialogs.ThirdPartyLicensesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexAccountSwitch.WinUI.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:CodexAccountSwitch.WinUI.Models"
    x:Uid="ThirdPartyLicensesDialog"
    DataContext="{x:Bind This}"
    DefaultButton="Close"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">
    <ContentDialog.Resources>
        <ResourceDictionary>
            <x:Double x:Key="ContentDialogMaxWidth">1000</x:Double>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid Width="760" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                x:Uid="ThirdPartyLicensesDialog_DescriptionTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8">
            <StackPanel Spacing="2">
                <TextBlock x:Uid="ThirdPartyLicensesDialog_NuGetPackageHeaderTextBlock" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock
                    x:Uid="ThirdPartyLicensesDialog_NuGetPackageDescriptionTextBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}">
                <ListView
                    MaxHeight="308"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ThirdPartyLicensePackages}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ThirdPartyLicensePackage">
                            <Grid Padding="0,12,0,12" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind PackageIdentifier}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind AuthorsText}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Uid="ThirdPartyLicensesDialog_VersionHeaderTextBlock" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind VersionText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock x:Uid="ThirdPartyLicensesDialog_LicenseHeaderTextBlock" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind LicenseText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Button
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    Click="OnPackageProjectButtonClicked"
                                    Tag="{x:Bind ProjectAddress}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                                        <TextBlock x:Uid="ThirdPartyLicensesDialog_ProjectButtonTextBlock" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>
