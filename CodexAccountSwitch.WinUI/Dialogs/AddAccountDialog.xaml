<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="CodexAccountSwitch.WinUI.Dialogs.AddAccountDialog"
    x:Uid="AddAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:CodexAccountSwitch.WinUI.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Closing="OnAddAccountDialogClosing"
    DefaultButton="Close"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <Grid
        Width="760"
        Height="560"
        RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <dev:SelectorBarSegmented
            x:Name="AddAccountModeSelectorBar"
            Grid.Row="0"
            HorizontalAlignment="Center"
            SelectedItem="{x:Bind OAuthSelectorBarItem}"
            SelectionChanged="OnAddAccountModeSelectorBarSelectionChanged">
            <SelectorBarItem
                x:Name="OAuthSelectorBarItem"
                x:Uid="AddAccountDialog_OAuthSelectorBarItem"
                Tag="OAuth" />
            <SelectorBarItem
                x:Uid="AddAccountDialog_ManualPasteSelectorBarItem"
                Tag="ManualPaste" />
            <SelectorBarItem
                x:Uid="AddAccountDialog_CurrentAccountSelectorBarItem"
                Tag="CurrentAccount" />
            <SelectorBarItem
                x:Uid="AddAccountDialog_FileSelectorBarItem"
                Tag="File" />
        </dev:SelectorBarSegmented>

        <Frame
            x:Name="AddAccountContentFrame"
            Grid.Row="1"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefault}" />
    </Grid>
</ContentDialog>
