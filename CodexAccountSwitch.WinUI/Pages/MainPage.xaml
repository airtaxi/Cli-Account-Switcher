<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="OnUnloaded"
    mc:Ignorable="d">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <dev:SelectorBarSegmented
            x:Name="PageSelectorBar"
            Grid.Row="0"
            HorizontalAlignment="Center"
            SelectedItem="{x:Bind DashboardSelectorBarItem}"
            SelectionChanged="OnPageSelectorBarSelectionChanged">
            <SelectorBarItem
                x:Name="DashboardSelectorBarItem"
                x:Uid="MainPage_DashboardSelectorBarItem"
                Tag="Dashboard">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xECA5;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem
                x:Name="AccountsSelectorBarItem"
                x:Uid="MainPage_AccountsSelectorBarItem"
                Tag="Accounts">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE748;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem
                x:Name="AboutSelectorBarItem"
                x:Uid="MainPage_AboutSelectorBarItem"
                Tag="About">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE946;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem
                x:Name="SettingsSelectorBarItem"
                x:Uid="MainPage_SettingsSelectorBarItem"
                Tag="Settings">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
        </dev:SelectorBarSegmented>

        <Frame
            x:Name="SectionContentFrame"
            Grid.Row="1"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefault}" />
    </Grid>
</Page>
