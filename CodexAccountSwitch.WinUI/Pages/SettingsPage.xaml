<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnSettingsPageLoaded"
    Unloaded="OnSettingsPageUnloaded"
    mc:Ignorable="d">

    <Grid Padding="24">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Stretch">
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="SettingsPage_TitleTextBlock" Style="{ThemeResource TitleLargeTextBlockStyle}" />
                    <TextBlock
                        x:Uid="SettingsPage_DescriptionTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_GeneralSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_LanguageSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE775;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="LanguageComboBox"
                            MinWidth="220"
                            SelectionChanged="OnLanguageComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultLanguageComboBoxItem" Tag="" />
                            <ComboBoxItem x:Uid="SettingsPage_KoreanLanguageComboBoxItem" Tag="ko-KR" />
                            <ComboBoxItem x:Uid="SettingsPage_EnglishLanguageComboBoxItem" Tag="en-US" />
                        </ComboBox>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_ThemeSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            MinWidth="220"
                            SelectionChanged="OnThemeComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultThemeComboBoxItem" Tag="Default" />
                            <ComboBoxItem x:Uid="SettingsPage_LightThemeComboBoxItem" Tag="Light" />
                            <ComboBoxItem x:Uid="SettingsPage_DarkThemeComboBoxItem" Tag="Dark" />
                        </ComboBox>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_UpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ApplicationVersionText}" />
                            <Button x:Name="CheckForUpdatesButton" Click="OnCheckForUpdatesButtonClicked">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                    <TextBlock x:Uid="SettingsPage_CheckForUpdatesButtonTextBlock" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_AutomaticUpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE9F5;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="AutomaticUpdateToggleSwitch" Toggled="OnAutomaticUpdateToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_StartupLaunchSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE945;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="StartupLaunchToggleSwitch" Toggled="OnStartupLaunchToggleSwitchToggled" />
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_AccountSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_ExpiredAccountAutomaticDeletionSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74D;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="ExpiredAccountAutomaticDeletionToggleSwitch" Toggled="OnExpiredAccountAutomaticDeletionToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_ExpiredAccountNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="ExpiredAccountNotificationToggleSwitch" Toggled="OnExpiredAccountNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsExpander x:Uid="SettingsPage_ActiveAccountUsageRefreshSettingsCard">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE7C1;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Content>
                            <ToggleSwitch x:Name="ActiveAccountUsageAutomaticRefreshToggleSwitch" Toggled="OnActiveAccountUsageAutomaticRefreshToggleSwitchToggled" />
                        </dev:SettingsExpander.Content>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_ActiveAccountUsageRefreshIntervalSettingsCard">
                                <NumberBox
                                    x:Name="ActiveAccountUsageRefreshIntervalNumberBox"
                                    MinWidth="140"
                                    LargeChange="5"
                                    Maximum="1440"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnActiveAccountUsageRefreshIntervalNumberBoxValueChanged" />
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_ActiveAccountNextUsageRefreshSettingsCard">
                                <TextBlock x:Name="ActiveAccountNextUsageRefreshTextBlock" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsExpander x:Uid="SettingsPage_InactiveAccountUsageRefreshSettingsCard">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE823;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Content>
                            <ToggleSwitch x:Name="InactiveAccountUsageAutomaticRefreshToggleSwitch" Toggled="OnInactiveAccountUsageAutomaticRefreshToggleSwitchToggled" />
                        </dev:SettingsExpander.Content>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_InactiveAccountUsageRefreshIntervalSettingsCard">
                                <NumberBox
                                    x:Name="InactiveAccountUsageRefreshIntervalNumberBox"
                                    MinWidth="140"
                                    LargeChange="5"
                                    Maximum="1440"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnInactiveAccountUsageRefreshIntervalNumberBoxValueChanged" />
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_InactiveAccountNextUsageRefreshSettingsCard">
                                <TextBlock x:Name="InactiveAccountNextUsageRefreshTextBlock" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageWarningThresholdSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xECAD;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                x:Name="PrimaryUsageWarningThresholdNumberBox"
                                MinWidth="120"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnPrimaryUsageWarningThresholdNumberBoxValueChanged" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="%" />
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_SecondaryUsageWarningThresholdSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xECAD;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                x:Name="SecondaryUsageWarningThresholdNumberBox"
                                MinWidth="120"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSecondaryUsageWarningThresholdNumberBoxValueChanged" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="%" />
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageLowQuotaNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="PrimaryUsageLowQuotaNotificationToggleSwitch" Toggled="OnPrimaryUsageLowQuotaNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_SecondaryUsageLowQuotaNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch x:Name="SecondaryUsageLowQuotaNotificationToggleSwitch" Toggled="OnSecondaryUsageLowQuotaNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
