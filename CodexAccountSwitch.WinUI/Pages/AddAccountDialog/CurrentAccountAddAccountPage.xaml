<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.AddAccountDialog.CurrentAccountAddAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexAccountSwitch.WinUI.Pages.AddAccountDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="로그인된 계정 불러오기" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="현재 Codex에 로그인된 .codex/auth.json을 읽고 Usage 요청으로 계정을 검증합니다."
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="ImportCurrentAccountButton"
                Click="OnImportCurrentAccountButtonClicked"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8B5;" />
                    <TextBlock Text="로그인된 계정 가져오기" />
                </StackPanel>
            </Button>
            <ProgressRing
                x:Name="CurrentAccountValidationProgressRing"
                Width="24"
                Height="24"
                IsActive="False"
                Visibility="Collapsed" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="읽을 파일" />
                <TextBlock
                    FontFamily="Consolas"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind CurrentAuthenticationFilePath}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <InfoBar
            x:Name="CurrentAccountErrorInfoBar"
            Grid.Row="3"
            IsOpen="False"
            Message="로그인된 계정을 불러오는 중 오류가 발생했습니다."
            Severity="Error"
            Title="계정 추가 실패" />
    </Grid>
</Page>
