<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.AddAccountDialog.FileAddAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexAccountSwitch.WinUI.Pages.AddAccountDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock
                x:Uid="FileAddAccountPage_TitleTextBlock"
                FontSize="22"
                FontWeight="SemiBold" />
            <TextBlock
                x:Uid="FileAddAccountPage_DescriptionTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="ImportAuthenticationFileButton"
                Click="OnImportAuthenticationFileButtonClicked"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                    <TextBlock x:Uid="FileAddAccountPage_ImportButtonTextBlock" />
                </StackPanel>
            </Button>
            <ProgressRing
                x:Name="FileValidationProgressRing"
                Width="24"
                Height="24"
                IsActive="False"
                Visibility="Collapsed" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">
                <TextBlock x:Uid="FileAddAccountPage_SupportedFormatHeaderTextBlock" FontWeight="SemiBold" />
                <TextBlock
                    x:Uid="FileAddAccountPage_SupportedFormatDescriptionTextBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <InfoBar
            x:Name="FileErrorInfoBar"
            x:Uid="FileAddAccountPage_ErrorInfoBar"
            Grid.Row="3"
            IsOpen="False"
            Severity="Error" />
    </Grid>
</Page>
