<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.AddAccountDialog.OAuthAddAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:CodexAccountSwitch.WinUI.Pages.AddAccountDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="OnOAuthAddAccountPageUnloaded"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock
                x:Uid="OAuthAddAccountPage_TitleTextBlock"
                FontSize="22"
                FontWeight="SemiBold" />
            <TextBlock
                x:Uid="OAuthAddAccountPage_DescriptionTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Button
            x:Name="OAuthOpenBrowserButton"
            Grid.Row="1"
            Click="OnOAuthOpenBrowserButtonClicked"
            Style="{StaticResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="15" Glyph="&#xE774;" />
                <TextBlock x:Uid="OAuthAddAccountPage_OpenBrowserTextBlock" />
            </StackPanel>
        </Button>

        <StackPanel
            x:Name="OAuthWaitingPanel"
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="10"
            Visibility="Collapsed">
            <dev:LoadingIndicator
                Width="24"
                Height="24"
                Foreground="{ThemeResource SystemAccentColor}"
                Mode="Arcs" />
            <TextBlock x:Uid="OAuthAddAccountPage_WaitingTextBlock" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel
            x:Name="OAuthManualAddressPanel"
            Grid.Row="3"
            Spacing="8"
            Visibility="Collapsed">
            <TextBlock
                x:Uid="OAuthAddAccountPage_ManualAddressDescriptionTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="OAuthManualAddressTextBox"
                    Grid.Column="0"
                    IsReadOnly="True" />
                <Button
                    x:Name="OAuthManualAddressCopyButton"
                    Grid.Column="1"
                    Click="OnOAuthManualAddressCopyButtonClicked">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="OAuthAddAccountPage_CopyAddressToolTip" />
                    </ToolTipService.ToolTip>
                    <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                </Button>
            </Grid>
        </StackPanel>

        <InfoBar
            x:Name="OAuthErrorInfoBar"
            x:Uid="OAuthAddAccountPage_ErrorInfoBar"
            Grid.Row="4"
            IsOpen="False"
            Severity="Error" />
    </Grid>
</Page>
