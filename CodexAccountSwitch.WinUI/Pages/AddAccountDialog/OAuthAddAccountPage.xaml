<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexAccountSwitch.WinUI.Pages.AddAccountDialog.OAuthAddAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:CodexAccountSwitch.WinUI.Pages.AddAccountDialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="OnOAuthAddAccountPageUnloaded"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="OAuth 인증" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="브라우저에서 Codex 인증을 완료하면 계정 사용량 검증 후 자동으로 추가됩니다."
                TextWrapping="Wrap" />
        </StackPanel>

        <Button
            x:Name="OAuthOpenBrowserButton"
            Grid.Row="1"
            Click="OnOAuthOpenBrowserButtonClicked"
            Style="{StaticResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon FontSize="15" Glyph="&#xE774;" />
                <TextBlock Text="브라우저에서 인증 시작" />
            </StackPanel>
        </Button>

        <StackPanel
            x:Name="OAuthWaitingPanel"
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="10"
            Visibility="Collapsed">
            <dev:LoadingIndicator
                Width="24"
                Height="24"
                Foreground="{ThemeResource SystemAccentColor}"
                Mode="Arcs" />
            <TextBlock
                VerticalAlignment="Center"
                Text="인증 콜백을 기다리는 중입니다." />
        </StackPanel>

        <StackPanel
            x:Name="OAuthManualAddressPanel"
            Grid.Row="3"
            Spacing="8"
            Visibility="Collapsed">
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="브라우저를 자동으로 열 수 없습니다. 아래 주소를 복사해서 브라우저에 붙여넣고 인증을 진행하세요."
                TextWrapping="Wrap" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="OAuthManualAddressTextBox"
                    Grid.Column="0"
                    IsReadOnly="True" />
                <Button
                    x:Name="OAuthManualAddressCopyButton"
                    Grid.Column="1"
                    Click="OnOAuthManualAddressCopyButtonClicked">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="복사" />
                    </ToolTipService.ToolTip>
                    <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                </Button>
            </Grid>
        </StackPanel>

        <InfoBar
            x:Name="OAuthErrorInfoBar"
            Grid.Row="4"
            IsOpen="False"
            Message="OAuth 인증 또는 계정 검증 중 오류가 발생했습니다."
            Severity="Error"
            Title="계정 추가 실패" />
    </Grid>
</Page>
