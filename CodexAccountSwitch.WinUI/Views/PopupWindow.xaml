<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="CodexAccountSwitch.WinUI.Views.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CodexAccountSwitch.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:CodexAccountSwitch.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    Width="450"
    Height="308"
    Activated="OnPopupWindowActivated"
    Closed="OnPopupWindowClosed"
    IsMaximizable="False"
    IsResizable="False"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Frame x:Name="RootFrame">
        <Grid x:Name="RootGrid" Loaded="OnRootGridLoaded">
            <Grid x:Name="ContentGrid" Padding="12">
                <controls:ActiveAccountQuotaControl
                    ShouldShowCardChrome="False"
                    ShouldShowRefreshButton="True"
                    ShouldUseMainWindowNavigation="True"
                    ViewModel="{x:Bind ViewModel}" />
            </Grid>

            <Grid x:Name="LoadingGrid" Visibility="Collapsed">
                <Rectangle Fill="{ThemeResource ThemeColor}" Opacity="0.3" />

                <dev:BlurEffectControl
                    BlurAmount="10"
                    IsBlurEnabled="True"
                    IsTintEnabled="False" />

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
                    <dev:LoadingIndicator Foreground="{ThemeResource SystemAccentColor}" Mode="Arcs" />
                    <TextBlock
                        x:Name="LoadingTextBlock"
                        HorizontalAlignment="Center"
                        FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Grid>
    </Frame>
</winuiex:WindowEx>
