<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CliAccountSwitcher.WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    DataContext="{x:Bind ViewModel}"
    Loaded="OnSettingsPageLoaded"
    Unloaded="OnSettingsPageUnloaded"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Padding="24">
            <StackPanel HorizontalAlignment="Stretch">
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="SettingsPage_TitleTextBlock" Style="{ThemeResource TitleLargeTextBlockStyle}" />
                    <TextBlock
                        x:Uid="SettingsPage_DescriptionTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_GeneralSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_LanguageSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE775;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="LanguageComboBox"
                            MinWidth="220"
                            SelectedIndex="{x:Bind ViewModel.LanguageSelectedIndex, Mode=TwoWay}"
                            SelectionChanged="OnLanguageComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_KoreanLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_EnglishLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_JapaneseLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_SimplifiedChineseLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_TraditionalChineseLanguageComboBoxItem" />
                        </ComboBox>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_ThemeSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            MinWidth="220"
                            SelectedIndex="{x:Bind ViewModel.ThemeSelectedIndex, Mode=TwoWay}"
                            SelectionChanged="OnThemeComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultThemeComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_LightThemeComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_DarkThemeComboBoxItem" />
                        </ComboBox>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_UpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.ApplicationVersionText}" />
                            <Button
                                x:Name="CheckForUpdatesButton"
                                Click="OnCheckForUpdatesButtonClicked"
                                IsEnabled="{x:Bind ViewModel.IsCheckForUpdatesButtonEnabled, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                    <TextBlock x:Uid="SettingsPage_CheckForUpdatesButtonTextBlock" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_AutomaticUpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE9F5;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="AutomaticUpdateToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsAutomaticUpdateCheckEnabled, Mode=TwoWay}"
                            Toggled="OnAutomaticUpdateToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_StartupLaunchSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE945;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="StartupLaunchToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsStartupLaunchEnabled, Mode=TwoWay}"
                            Toggled="OnStartupLaunchToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_TaskbarUsageSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE9D2;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="TaskbarUsageToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsTaskbarUsageVisible, Mode=TwoWay}"
                            Toggled="OnTaskbarUsageToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsExpander x:Uid="SettingsPage_ApplicationSettingsTransferSettingsExpander">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A5;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_ExportApplicationSettingsSettingsCard">
                                <Button
                                    x:Name="ExportApplicationSettingsButton"
                                    Click="OnExportApplicationSettingsButtonClicked"
                                    IsEnabled="{x:Bind ViewModel.IsExportApplicationSettingsButtonEnabled, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xEDE1;" />
                                        <TextBlock x:Uid="SettingsPage_ExportApplicationSettingsButtonTextBlock" />
                                    </StackPanel>
                                </Button>
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_ImportApplicationSettingsSettingsCard">
                                <Button
                                    x:Name="ImportApplicationSettingsButton"
                                    Click="OnImportApplicationSettingsButtonClicked"
                                    IsEnabled="{x:Bind ViewModel.IsImportApplicationSettingsButtonEnabled, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8B5;" />
                                        <TextBlock x:Uid="SettingsPage_ImportApplicationSettingsButtonTextBlock" />
                                    </StackPanel>
                                </Button>
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsCard x:Uid="SettingsPage_IntegratedLogExportSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7BA;" />
                        </dev:SettingsCard.HeaderIcon>
                        <Button
                            x:Name="ExportIntegratedLogButton"
                            Click="OnExportIntegratedLogButtonClicked"
                            IsEnabled="{x:Bind ViewModel.IsExportIntegratedLogButtonEnabled, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xEDE1;" />
                                <TextBlock x:Uid="SettingsPage_ExportIntegratedLogButtonTextBlock" />
                            </StackPanel>
                        </Button>
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_AccountSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_ExpiredAccountAutomaticDeletionSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74D;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="ExpiredAccountAutomaticDeletionToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsExpiredAccountAutomaticDeletionEnabled, Mode=TwoWay}"
                            Toggled="OnExpiredAccountAutomaticDeletionToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_ExpiredAccountNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="ExpiredAccountNotificationToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsExpiredAccountNotificationEnabled, Mode=TwoWay}"
                            Toggled="OnExpiredAccountNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsExpander x:Uid="SettingsPage_ActiveAccountUsageRefreshSettingsCard">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE7C1;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Content>
                            <ToggleSwitch
                                x:Name="ActiveAccountUsageAutomaticRefreshToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsActiveAccountUsageAutomaticRefreshEnabled, Mode=TwoWay}"
                                Toggled="OnActiveAccountUsageAutomaticRefreshToggleSwitchToggled" />
                        </dev:SettingsExpander.Content>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_ActiveAccountUsageRefreshIntervalSettingsCard">
                                <NumberBox
                                    x:Name="ActiveAccountUsageRefreshIntervalNumberBox"
                                    MinWidth="140"
                                    IsEnabled="{x:Bind ViewModel.IsActiveAccountUsageRefreshIntervalEnabled, Mode=OneWay}"
                                    LargeChange="5"
                                    Maximum="1440"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnActiveAccountUsageRefreshIntervalNumberBoxValueChanged"
                                    Value="{x:Bind ViewModel.ActiveAccountUsageRefreshIntervalMinutes, Mode=TwoWay}" />
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_ActiveAccountNextUsageRefreshSettingsCard">
                                <TextBlock
                                    x:Name="ActiveAccountNextUsageRefreshTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.ActiveAccountNextUsageRefreshText, Mode=OneWay}" />
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsExpander x:Uid="SettingsPage_InactiveAccountUsageRefreshSettingsCard">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE823;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Content>
                            <ToggleSwitch
                                x:Name="InactiveAccountUsageAutomaticRefreshToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsInactiveAccountUsageAutomaticRefreshEnabled, Mode=TwoWay}"
                                Toggled="OnInactiveAccountUsageAutomaticRefreshToggleSwitchToggled" />
                        </dev:SettingsExpander.Content>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_InactiveAccountUsageRefreshIntervalSettingsCard">
                                <NumberBox
                                    x:Name="InactiveAccountUsageRefreshIntervalNumberBox"
                                    MinWidth="140"
                                    IsEnabled="{x:Bind ViewModel.IsInactiveAccountUsageRefreshIntervalEnabled, Mode=OneWay}"
                                    LargeChange="5"
                                    Maximum="1440"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnInactiveAccountUsageRefreshIntervalNumberBoxValueChanged"
                                    Value="{x:Bind ViewModel.InactiveAccountUsageRefreshIntervalMinutes, Mode=TwoWay}" />
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_InactiveAccountNextUsageRefreshSettingsCard">
                                <TextBlock
                                    x:Name="InactiveAccountNextUsageRefreshTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.InactiveAccountNextUsageRefreshText, Mode=OneWay}" />
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageWarningThresholdSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xECAD;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                x:Name="PrimaryUsageWarningThresholdNumberBox"
                                MinWidth="120"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnPrimaryUsageWarningThresholdNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.PrimaryUsageWarningThresholdPercentage, Mode=TwoWay}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="%" />
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_SecondaryUsageWarningThresholdSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xECAD;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                x:Name="SecondaryUsageWarningThresholdNumberBox"
                                MinWidth="120"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="OnSecondaryUsageWarningThresholdNumberBoxValueChanged"
                                Value="{x:Bind ViewModel.SecondaryUsageWarningThresholdPercentage, Mode=TwoWay}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="%" />
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageLowQuotaNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="PrimaryUsageLowQuotaNotificationToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsPrimaryUsageLowQuotaNotificationEnabled, Mode=TwoWay}"
                            Toggled="OnPrimaryUsageLowQuotaNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>

                    <dev:SettingsExpander x:Uid="SettingsPage_PrimaryUsageSurgeNotificationSettingsCard">
                        <dev:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsExpander.HeaderIcon>
                        <dev:SettingsExpander.Content>
                            <ToggleSwitch
                                x:Name="PrimaryUsageSurgeNotificationToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsPrimaryUsageSurgeNotificationEnabled, Mode=TwoWay}"
                                Toggled="OnPrimaryUsageSurgeNotificationToggleSwitchToggled" />
                        </dev:SettingsExpander.Content>
                        <dev:SettingsExpander.Items>
                            <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageSurgeNotificationThresholdSettingsCard">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <NumberBox
                                        x:Name="PrimaryUsageSurgeNotificationThresholdNumberBox"
                                        MinWidth="120"
                                        IsEnabled="{x:Bind ViewModel.IsPrimaryUsageSurgeNotificationSettingsEnabled, Mode=OneWay}"
                                        Maximum="100"
                                        Minimum="1"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Inline"
                                        ValueChanged="OnPrimaryUsageSurgeNotificationThresholdNumberBoxValueChanged"
                                        Value="{x:Bind ViewModel.PrimaryUsageSurgeNotificationThresholdPercentage, Mode=TwoWay}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="%" />
                                </StackPanel>
                            </dev:SettingsCard>
                            <dev:SettingsCard x:Uid="SettingsPage_PrimaryUsageSurgeNotificationWindowSettingsCard">
                                <NumberBox
                                    x:Name="PrimaryUsageSurgeNotificationWindowNumberBox"
                                    MinWidth="120"
                                    IsEnabled="{x:Bind ViewModel.IsPrimaryUsageSurgeNotificationSettingsEnabled, Mode=OneWay}"
                                    LargeChange="5"
                                    Maximum="300"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="OnPrimaryUsageSurgeNotificationWindowNumberBoxValueChanged"
                                    Value="{x:Bind ViewModel.PrimaryUsageSurgeNotificationWindowMinutes, Mode=TwoWay}" />
                            </dev:SettingsCard>
                        </dev:SettingsExpander.Items>
                    </dev:SettingsExpander>

                    <dev:SettingsCard x:Uid="SettingsPage_SecondaryUsageLowQuotaNotificationSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7F4;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="SecondaryUsageLowQuotaNotificationToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsSecondaryUsageLowQuotaNotificationEnabled, Mode=TwoWay}"
                            Toggled="OnSecondaryUsageLowQuotaNotificationToggleSwitchToggled" />
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
