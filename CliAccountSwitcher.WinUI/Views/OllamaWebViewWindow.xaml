<?xml version="1.0" encoding="utf-8" ?>
<dev:ModalWindow
    x:Class="CliAccountSwitcher.WinUI.Views.OllamaWebViewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Closed="OnOllamaWebViewWindowClosed"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Icon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1">
            <WebView2 x:Name="LoginWebView2" NavigationCompleted="OnLoginWebView2NavigationCompleted" />

            <StackPanel
                x:Name="WebViewLoadingPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="Collapsed">
                <ProgressRing
                    Width="48"
                    Height="48"
                    IsActive="True" />
                <TextBlock
                    x:Uid="OllamaWebViewLoginAddAccountPage_InitializingWebViewTextBlock"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel
                x:Name="ExtractionStatusPanel"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="Collapsed">
                <ProgressRing
                    x:Name="StatusProgressRing"
                    Width="24"
                    Height="24"
                    IsActive="False" />
                <TextBlock
                    x:Name="StatusTextBlock"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <InfoBar
                x:Name="ErrorInfoBar"
                Margin="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                IsOpen="False"
                Severity="Error" />
        </Grid>
    </Grid>
</dev:ModalWindow>