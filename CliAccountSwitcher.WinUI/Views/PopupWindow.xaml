<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="CliAccountSwitcher.WinUI.Views.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CliAccountSwitcher.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:CliAccountSwitcher.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    Width="500"
    MinHeight="0"
    Activated="OnPopupWindowActivated"
    Closed="OnPopupWindowClosed"
    IsMaximizable="False"
    IsResizable="False"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Frame x:Name="RootFrame" Loaded="OnRootFrameLoaded">
        <Grid x:Name="RootGrid">
            <Grid x:Name="ContentGrid" Padding="12">
                <controls:ActiveAccountQuotaControl
                    DashboardViewModel="{x:Bind ViewModel}"
                    ShouldShowCardChrome="False"
                    ShouldShowRefreshButton="True"
                    ShouldUseMainWindowNavigation="True" />

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="8">
                    <ComboBox
                        x:Name="ProviderComboBox"
                        MinWidth="132"
                        SelectionChanged="OnProviderComboBoxSelectionChanged">
                        <ComboBoxItem x:Uid="Provider_CodexComboBoxItem" />
                        <ComboBoxItem x:Uid="Provider_ClaudeCodeComboBoxItem" />
                        <ComboBoxItem x:Uid="Provider_ZaiComboBoxItem" />
                        <ComboBoxItem x:Uid="Provider_OpenCodeGoComboBoxItem" />
                        <ComboBoxItem x:Uid="Provider_OllamaComboBoxItem" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Grid x:Name="LoadingGrid" Visibility="Collapsed">
                <Rectangle Fill="{ThemeResource ThemeColor}" Opacity="0.3" />

                <dev:BlurEffectControl
                    BlurAmount="10"
                    IsBlurEnabled="True"
                    IsTintEnabled="False" />

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
                    <dev:LoadingIndicator Foreground="{ThemeResource SystemAccentColor}" Mode="Arcs" />
                    <TextBlock
                        x:Name="LoadingTextBlock"
                        HorizontalAlignment="Center"
                        FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Grid>
    </Frame>
</winuiex:WindowEx>
