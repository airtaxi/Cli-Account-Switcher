<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="CliAccountSwitcher.WinUI.Views.TaskbarUsageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CliAccountSwitcher.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ex="using:WinUIEx"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Taskbar usage"
    Closed="OnTaskbarUsageWindowClosed"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <ex:TransparentTintBackdrop />
    </Window.SystemBackdrop>

    <controls:TaskbarUsageControl x:Name="TaskbarUsageContent" />
</Window>
