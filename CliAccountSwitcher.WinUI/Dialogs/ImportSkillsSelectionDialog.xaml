<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="CliAccountSwitcher.WinUI.Dialogs.ImportSkillsSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CliAccountSwitcher.WinUI.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:CliAccountSwitcher.WinUI.Models"
    x:Uid="ImportSkillsSelectionDialog"
    Closed="OnImportSkillsSelectionDialogClosed"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.IsPrimaryButtonEnabled, Mode=OneWay}"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="ImportSkillsSelectionDialog_DescriptionTextBlock"
            Grid.Row="0"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap" />

        <AutoSuggestBox
            x:Name="SkillSearchAutoSuggestBox"
            x:Uid="ImportSkillsSelectionDialog_SearchAutoSuggestBox"
            Grid.Row="1"
            QueryIcon="Find"
            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox
                x:Name="SelectAllSkillsCheckBox"
                Grid.Column="0"
                Checked="OnSelectAllSkillsCheckBoxChecked"
                IsChecked="{x:Bind ViewModel.AllSkillsSelectionState, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.HasFilteredSkills, Mode=OneWay}"
                IsThreeState="{x:Bind ViewModel.IsSelectAllSkillsCheckBoxThreeState, Mode=OneWay}"
                Unchecked="OnSelectAllSkillsCheckBoxUnchecked">
                <TextBlock x:Uid="ImportSkillsSelectionDialog_SelectAllTextBlock" FontWeight="SemiBold" />
            </CheckBox>

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.SelectedCountText, Mode=OneWay}" />
        </Grid>

        <Border
            Grid.Row="3"
            Padding="4"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <ListView
                    x:Name="SkillsListView"
                    Background="Transparent"
                    ItemsSource="{x:Bind ViewModel.FilteredSkills, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,2" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SkillItem">
                            <Border
                                MinHeight="64"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="3">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            MaxLines="2"
                                            Text="{x:Bind Description, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap">
                                            <ToolTipService.ToolTip>
                                                <ToolTip>
                                                    <TextBlock
                                                        MaxWidth="520"
                                                        Text="{x:Bind Description, Mode=OneWay}"
                                                        TextWrapping="Wrap" />
                                                </ToolTip>
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.HasNoSkills, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Glyph="&#xE943;" />
                    <TextBlock
                        x:Uid="ImportSkillsSelectionDialog_NoSkillsTextBlock"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ContentDialog>