<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="CliAccountSwitcher.WinUI.Controls.TaskbarUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="48"
    d:DesignWidth="250"
    CornerRadius="4"
    Loaded="OnTaskbarUsageControlLoaded"
    mc:Ignorable="d">

    <Button
        x:Name="RootButton"
        Margin="2"
        Padding="4"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Background="Transparent"
        BorderBrush="Transparent"
        Click="OnRootButtonClicked">
        <Grid
            x:Name="RootGrid"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="Transparent"
            ColumnSpacing="2"
            RowSpacing="4"
            SizeChanged="OnButtonGridSizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="26" />
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center">
                <ProgressBar
                    Height="4"
                    Canvas.ZIndex="{x:Bind ViewModel.PrimaryUsageRemainingProgressBarZIndex, Mode=OneWay}"
                    Foreground="{ThemeResource ReverseThemeColor}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.PrimaryUsageRemainingPercentage, Mode=OneWay}" />
                <ProgressBar
                    Height="4"
                    Canvas.ZIndex="{x:Bind ViewModel.PrimaryUsagePacemakerProgressBarZIndex, Mode=OneWay}"
                    Foreground="{x:Bind ViewModel.IsPrimaryUsageBelowPacemaker, Mode=OneWay, Converter={StaticResource UsagePacemakerForegroundBrushConverter}}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.PrimaryUsagePacemakerPercentage, Mode=OneWay}" />
            </Grid>

            <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="ExtraBold"
                Foreground="{ThemeResource ReverseThemeColor}"
                MaxLines="1"
                Text="{x:Bind ViewModel.PrimaryUsageRemainingPercentageText, Mode=OneWay}"
                TextLineBounds="TrimToCapHeight" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="ExtraBold"
                Foreground="{x:Bind ViewModel.IsPrimaryUsageBelowPacemaker, Mode=OneWay, Converter={StaticResource UsagePacemakerForegroundBrushConverter}}"
                MaxLines="1"
                Text="{x:Bind ViewModel.PrimaryUsagePacemakerPercentageText, Mode=OneWay}"
                TextLineBounds="TrimToCapHeight" />

            <Grid
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center">
                <ProgressBar
                    Height="4"
                    Canvas.ZIndex="{x:Bind ViewModel.SecondaryUsageRemainingProgressBarZIndex, Mode=OneWay}"
                    Foreground="{ThemeResource ReverseThemeColor}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.SecondaryUsageRemainingPercentage, Mode=OneWay}" />
                <ProgressBar
                    Height="4"
                    Canvas.ZIndex="{x:Bind ViewModel.SecondaryUsagePacemakerProgressBarZIndex, Mode=OneWay}"
                    Foreground="{x:Bind ViewModel.IsSecondaryUsageBelowPacemaker, Mode=OneWay, Converter={StaticResource UsagePacemakerForegroundBrushConverter}}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.SecondaryUsagePacemakerPercentage, Mode=OneWay}" />
            </Grid>

            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="ExtraBold"
                Foreground="{ThemeResource ReverseThemeColor}"
                MaxLines="1"
                Text="{x:Bind ViewModel.SecondaryUsageRemainingPercentageText, Mode=OneWay}"
                TextLineBounds="TrimToCapHeight" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="ExtraBold"
                Foreground="{x:Bind ViewModel.IsSecondaryUsageBelowPacemaker, Mode=OneWay, Converter={StaticResource UsagePacemakerForegroundBrushConverter}}"
                MaxLines="1"
                Text="{x:Bind ViewModel.SecondaryUsagePacemakerPercentageText, Mode=OneWay}"
                TextLineBounds="TrimToCapHeight" />

            <Button
                x:Name="RefreshActiveAccountButton"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="3"
                Width="26"
                Height="26"
                Padding="0"
                VerticalAlignment="Center"
                AutomationProperties.Name="{x:Bind ViewModel.RefreshButtonToolTipText, Mode=OneWay}"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{x:Bind ViewModel.RefreshActiveAccountCommand}"
                IsEnabled="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                ToolTipService.ToolTip="{x:Bind ViewModel.RefreshButtonToolTipText, Mode=OneWay}">
                <FontIcon FontSize="12" Glyph="&#xE72C;" />
            </Button>

            <Grid
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="-8,-4"
                Visibility="{x:Bind ViewModel.IsRefreshing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Rectangle Fill="{ThemeResource ThemeColor}" Opacity="0.3" />

                <dev:BlurEffectControl
                    BlurAmount="10"
                    IsBlurEnabled="True"
                    IsTintEnabled="False" />

                <ProgressRing
                    Width="32"
                    Height="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource ReverseThemeColor}" />
            </Grid>
        </Grid>
    </Button>
</UserControl>
